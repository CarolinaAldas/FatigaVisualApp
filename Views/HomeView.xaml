<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.HomeView"
             Title="Inicio">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="{Binding NombreUsuario, StringFormat='Hola, {0} 👋'}"
                           FontSize="22" FontAttributes="Bold" TextColor="#1A1A1A"/>
                    <Label Text="{Binding Fecha}"
                           FontSize="13" TextColor="#888"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="Salir"
                        BackgroundColor="Transparent"
                        TextColor="#E24B4A"
                        FontSize="13"
                        Command="{Binding CerrarSesionCommand}"/>
            </Grid>

            <!-- Score card -->
            <Frame BackgroundColor="#1D9E75" CornerRadius="20"
                   Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Índice de fatiga visual"
                           FontSize="12" TextColor="White" Opacity="0.85"/>
                    <Label Text="{Binding IndiceFatiga}"
                           FontSize="52" FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{Binding NivelFatiga}"
                           FontSize="13" TextColor="White" Opacity="0.9"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Stats row -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Frame Grid.Column="0" CornerRadius="14" Padding="16"
                       BackgroundColor="White" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="{Binding PausasHoy}"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="#1D9E75"/>
                        <Label Text="Pausas hoy"
                               FontSize="12" TextColor="#888"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" CornerRadius="14" Padding="16"
                       BackgroundColor="White" HasShadow="True">
                    <VerticalStackLayout>
                        <Label Text="{Binding RachaDias, StringFormat='🔥 {0}'}"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="#1D9E75"/>
                        <Label Text="Días seguidos"
                               FontSize="12" TextColor="#888"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Acciones rápidas -->
            <Label Text="Acciones rápidas" FontSize="15"
                   FontAttributes="Bold" TextColor="#1A1A1A"
                   Margin="0,8,0,0"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,0">
                <Frame Grid.Column="0" CornerRadius="14" Padding="16"
           BackgroundColor="White" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrALearnCommand}"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout>
                        <Label Text="📚" FontSize="24"/>
                        <Label Text="Aprende" FontSize="13"
                   FontAttributes="Bold" TextColor="#1A1A1A"/>
                        <Label Text="Tips y ejercicios"
                   FontSize="11" TextColor="#888"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" CornerRadius="14" Padding="16"
           BackgroundColor="White" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrANotificacionesCommand}"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout>
                        <Label Text="🔔" FontSize="24"/>
                        <Label Text="Recordatorios" FontSize="13"
                   FontAttributes="Bold" TextColor="#1A1A1A"/>
                        <Label Text="Pausas activas"
                   FontSize="11" TextColor="#888"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>