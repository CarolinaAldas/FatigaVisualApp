<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.HomeView"
             BackgroundColor="white"
             Title="Inicio">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="{Binding NombreUsuario, StringFormat='Hola, {0} 👋'}"
                           FontSize="24" FontAttributes="Bold" TextColor="#2D3436"/>
                    <Label Text="{Binding Fecha}"
                           FontSize="14" TextColor="#636E72"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="Salir"
                        BackgroundColor="Transparent"
                        TextColor="#D63031"
                        FontSize="14"
                        VerticalOptions="Center"
                        Command="{Binding CerrarSesionCommand}"/>
            </Grid>

            <!-- Score card -->
            <Border BackgroundColor="#1D9E75" 
                    StrokeShape="RoundRectangle 24"
                    Padding="24" 
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Índice de fatiga visual"
                           FontSize="14" TextColor="White" Opacity="0.9"/>
                    <Label Text="{Binding IndiceFatiga}"
                           FontSize="56" FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{Binding NivelFatiga}"
                           FontSize="15" TextColor="White" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <!-- Stats row -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 16" Padding="16"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <VerticalStackLayout>
                        <Label Text="{Binding PausasHoy}" FontSize="28" FontAttributes="Bold" TextColor="#1D9E75" HorizontalOptions="Center"/>
                        <Label Text="Pausas hoy" FontSize="13" TextColor="#636E72" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Padding="16"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <VerticalStackLayout>
                        <Label Text="{Binding RachaDias, StringFormat='{0} días'}" FontSize="28" FontAttributes="Bold" TextColor="#1D9E75" HorizontalOptions="Center"/>
                        <Label Text="Racha" FontSize="13" TextColor="#636E72" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label Text="¿Qué desea hacer hoy?" FontSize="18"
                   FontAttributes="Bold" TextColor="#2D3436"/>

            <!-- Botones de navegación (4 en total) -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="16" RowSpacing="16">

                <!-- Aprender -->
                <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 16" Padding="20"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrALearnCommand}"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📚" FontSize="32" HorizontalOptions="Center"/>
                        <Label Text="Aprender" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Recordatorios -->
                <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 16" Padding="20"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrANotificacionesCommand}"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🔔" FontSize="32" HorizontalOptions="Center"/>
                        <Label Text="Alertas" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Quiz -->
                <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 16" Padding="20"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrAQuizCommand}"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📝" FontSize="32" HorizontalOptions="Center"/>
                        <Label Text="Quiz" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats -->
                <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 16" Padding="20"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrAStatsCommand}"/>
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📊" FontSize="32" HorizontalOptions="Center"/>
                        <Label Text="Progreso" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>