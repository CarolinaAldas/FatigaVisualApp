<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.QuizView"
             BackgroundColor="white"
             Title="Evaluación visual">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding Mensaje}" FontSize="13" TextColor="#636E72"/>
                <ProgressBar Progress="{Binding Progreso}"
                             ProgressColor="#1D9E75"
                             HeightRequest="8"/>
            </VerticalStackLayout>

            <Border StrokeShape="RoundRectangle 16" Padding="20"
                    BackgroundColor="White" Stroke="#F5F5F5" StrokeThickness="1">
                <Label Text="{Binding TextoPregunta}"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="#2D3436" LineBreakMode="WordWrap"/>
            </Border>

            <CollectionView ItemsSource="{Binding Opciones}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Margin="0,6" StrokeShape="RoundRectangle 12"
                                Padding="16" StrokeThickness="1"
                                Stroke="#E0E0E0" BackgroundColor="White">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarOpcionCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Label Text="{Binding .}" FontSize="15" TextColor="#2D3436"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border StrokeShape="RoundRectangle 12" Padding="12"
                    BackgroundColor="#E1F5EE" StrokeThickness="0">
                <Label Text="{Binding OpcionSeleccionada, StringFormat='✓  {0}'}"
                       FontSize="14" FontAttributes="Bold" TextColor="#085041"/>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,8,0,20">
                <Button Grid.Column="0"
                        Text="← Anterior"
                        BackgroundColor="Transparent"
                        TextColor="#1D9E75"
                        BorderColor="#1D9E75"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="50"
                        Command="{Binding AnteriorCommand}"/>
                <Button Grid.Column="1"
                        Text="Siguiente →"
                        BackgroundColor="#1D9E75"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="50"
                        Command="{Binding SiguienteCommand}"/>
            </Grid>

            <ActivityIndicator IsRunning="{Binding Cargando}"
                               IsVisible="{Binding Cargando}"
                               Color="#1D9E75"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>