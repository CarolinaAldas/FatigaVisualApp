<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.SplashView"
             BackgroundColor="#080e15"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Glow de fondo -->
        <Ellipse x:Name="AmbientGlow"
                 WidthRequest="320" HeightRequest="200"
                 HorizontalOptions="Center" VerticalOptions="Center"
                 Margin="0,-60,0,0"
                 Opacity="0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0D2A4A" Offset="0"/>
                    <GradientStop Color="#080e15" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Contenido central -->
        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="0">

            <!-- Ojo cerrado (inicio) -->
            <Image x:Name="EyeClosed"
                   Source="eye_closed.png"
                   WidthRequest="280"
                   HeightRequest="196"
                   HorizontalOptions="Center"
                   Opacity="1"/>

            <!-- Ojo abierto (aparece después) -->
            <Image x:Name="EyeOpen"
                   Source="eye_open.png"
                   WidthRequest="280"
                   HeightRequest="196"
                   HorizontalOptions="Center"
                   Opacity="0"
                   Margin="0,-196,0,0"/>

            <!-- Texto -->
            <VerticalStackLayout x:Name="TextBlock"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 Margin="0,28,0,0"
                                 Opacity="0"
                                 TranslationY="12">

                <Label Text="FATIGAVISUAL"
                       FontSize="22"
                       CharacterSpacing="10"
                       TextColor="#D8EDF8"
                       HorizontalOptions="Center"/>

                <BoxView HeightRequest="1" WidthRequest="40"
                         Color="#3898DC"
                         HorizontalOptions="Center"/>

                <Label Text="Cuida tu salud visual"
                       FontSize="11"
                       FontAttributes="Italic"
                       CharacterSpacing="2"
                       TextColor="#4FA8D8"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- Dots loader -->
        <HorizontalStackLayout x:Name="DotsLoader"
                               HorizontalOptions="Center"
                               VerticalOptions="End"
                               Margin="0,0,0,55"
                               Spacing="10"
                               Opacity="0">
            <Ellipse x:Name="Dot1" WidthRequest="7" HeightRequest="7"
                     Fill="#3898DC" Opacity="0.2"/>
            <Ellipse x:Name="Dot2" WidthRequest="7" HeightRequest="7"
                     Fill="#3898DC" Opacity="0.2"/>
            <Ellipse x:Name="Dot3" WidthRequest="7" HeightRequest="7"
                     Fill="#3898DC" Opacity="0.2"/>
        </HorizontalStackLayout>

    </Grid>
</ContentPage>