<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.LearnView"
             BackgroundColor="white"
             Title="Aprende">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Header -->
            <StackLayout Spacing="4">
                <Label Text="Aprende" FontSize="26" FontAttributes="Bold" TextColor="#2D3436"/>
                <Label Text="Consejos y ejercicios visuales" FontSize="14" TextColor="#636E72"/>
            </StackLayout>

            <!-- Filtros -->
            <HorizontalStackLayout Spacing="10">
                <Button Text="Todos" BackgroundColor="#1D9E75" TextColor="White" 
                        CornerRadius="20" HeightRequest="40" Padding="20,0" Command="{Binding FiltrarCommand}" CommandParameter="Todos"/>
                <Button Text="Ejercicios" BackgroundColor="#F5F5F5" TextColor="#636E72" 
                        CornerRadius="20" HeightRequest="40" Padding="20,0" Command="{Binding FiltrarCommand}" CommandParameter="Ejercicios"/>
                <Button Text="Tests" BackgroundColor="#F5F5F5" TextColor="#636E72" 
                        CornerRadius="20" HeightRequest="40" Padding="20,0" Command="{Binding FiltrarCommand}" CommandParameter="Tests"/>
            </HorizontalStackLayout>

            <!-- Módulos -->
            <CollectionView ItemsSource="{Binding ModulosFiltrados}"
                            SelectionMode="None"
                            Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border Margin="0,8" StrokeShape="RoundRectangle 16"
                                Padding="16" StrokeThickness="1"
                                Stroke="#F5F5F5" BackgroundColor="White">
                            <VerticalStackLayout Spacing="12">
                                <!-- Cabecera del ítem -->
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12"
                                            WidthRequest="48" HeightRequest="48"
                                            Padding="0" StrokeThickness="0"
                                            BackgroundColor="{Binding ColorFondo}">
                                        <Label Text="{Binding Icono}" FontSize="24"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="12,0">
                                        <Label Text="{Binding Titulo}" FontSize="15" FontAttributes="Bold" TextColor="#2D3436"/>
                                        <Label Text="{Binding Descripcion}" FontSize="13" TextColor="#636E72"/>
                                    </VerticalStackLayout>

                                    <Border Grid.Column="2" StrokeShape="RoundRectangle 8" Padding="8,4"
                                            BackgroundColor="{Binding ColorFondo}" StrokeThickness="0">
                                        <Label Text="{Binding Etiqueta}" FontSize="11" FontAttributes="Bold" TextColor="{Binding ColorEtiqueta}"/>
                                    </Border>
                                </Grid>

                                <!-- Detalle con fondo suave -->
                                <Border BackgroundColor="#F8F9FA" StrokeThickness="0" 
                                        StrokeShape="RoundRectangle 12" Padding="12">
                                    <Label Text="{Binding Detalle}" FontSize="13" TextColor="#636E72" LineBreakMode="WordWrap"/>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>