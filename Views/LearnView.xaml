<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.LearnView"
             Title="Aprende">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Header -->
            <Label Text="Aprende" FontSize="22" FontAttributes="Bold"
                   TextColor="#1A1A1A" Margin="0,10,0,0"/>
            <Label Text="Consejos y ejercicios visuales"
                   FontSize="13" TextColor="#888"/>

            
            <!-- Filtros -->
            <HorizontalStackLayout Spacing="8" Margin="0,4,0,4">
                <Button Text="Todos"
            BackgroundColor="#1D9E75"
            TextColor="White" CornerRadius="20"
            FontSize="12" Padding="14,6"
            Command="{Binding FiltrarCommand}"
            CommandParameter="Todos"/>
                <Button Text="Ejercicios"
            BackgroundColor="#AAAAAA"
            TextColor="White" CornerRadius="20"
            FontSize="12" Padding="14,6"
            Command="{Binding FiltrarCommand}"
            CommandParameter="Ejercicios"/>
                <Button Text="Tests"
            BackgroundColor="#AAAAAA"
            TextColor="White" CornerRadius="20"
            FontSize="12" Padding="14,6"
            Command="{Binding FiltrarCommand}"
            CommandParameter="Tests"/>
                <Button Text="Tips"
            BackgroundColor="#AAAAAA"
            TextColor="White" CornerRadius="20"
            FontSize="12" Padding="14,6"
            Command="{Binding FiltrarCommand}"
            CommandParameter="Tips"/>
            </HorizontalStackLayout>
            
            <!-- Módulos -->
            <CollectionView ItemsSource="{Binding ModulosFiltrados}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Frame Margin="0,4" CornerRadius="16"
                               Padding="0" HasShadow="True"
                               BorderColor="#E5E5E5"
                               BackgroundColor="White">
                            <Grid RowDefinitions="Auto,Auto">
                                <!-- Header tarjeta -->
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
                                      Padding="14" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="10"
                                           WidthRequest="44" HeightRequest="44"
                                           Padding="0"
                                           BackgroundColor="{Binding ColorFondo}">
                                        <Label Text="{Binding Icono}"
                                               FontSize="22"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Titulo}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="#1A1A1A"/>
                                        <Label Text="{Binding Descripcion}"
                                               FontSize="12" TextColor="#888"
                                               Margin="0,2,0,0"/>
                                    </VerticalStackLayout>
                                    <Frame Grid.Column="2" CornerRadius="10"
                                           Padding="6,3"
                                           BackgroundColor="{Binding ColorFondo}"
                                           VerticalOptions="Center">
                                        <Label Text="{Binding Etiqueta}"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="{Binding ColorEtiqueta}"/>
                                    </Frame>
                                </Grid>

                                <!-- Detalle -->
                                <Frame Grid.Row="1" Margin="14,0,14,14"
                                       CornerRadius="10" Padding="12"
                                       BackgroundColor="#F8F8F8"
                                       BorderColor="#EEEEEE">
                                    <Label Text="{Binding Detalle}"
                                           FontSize="12" TextColor="#555"
                                           LineBreakMode="WordWrap"/>
                                </Frame>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>