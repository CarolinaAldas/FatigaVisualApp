<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.RegistroView"
             BackgroundColor="#080e15"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,40" Spacing="0">

            <!-- Logo y título -->
            <Image Source="logo.png"
                   WidthRequest="90" HeightRequest="90"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16"/>

            <Label Text="Crear cuenta"
                   FontSize="26" FontAttributes="Bold"
                   TextColor="#D8EDF8"
                   HorizontalOptions="Center"
                   CharacterSpacing="1"/>

            <Label Text="Regístrate para comenzar a cuidar tu visión"
                   FontSize="13" FontAttributes="Italic"
                   TextColor="#4FA8D8"
                   HorizontalOptions="Center"
                   Margin="0,4,0,32"/>

            <!-- Card -->
            <Border BackgroundColor="#0f1923"
                    StrokeThickness="1"
                    Padding="28,32">
                <Border.Stroke>
                    <SolidColorBrush Color="#1a3040"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="14">

                    <!-- Botón Google -->
                    <Border BackgroundColor="#162030"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1e3a50"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Button Text="Continuar con Google"
                                Command="{Binding LoginGoogleCommand}"
                                HeightRequest="52"
                                BackgroundColor="Transparent"
                                TextColor="#D8EDF8"
                                FontSize="14"
                                FontAttributes="Bold"/>
                    </Border>

                    <!-- Separador -->
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,4,0,4">
                        <BoxView Grid.Column="0" HeightRequest="1"
                                 Color="#1a3040" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="o regístrate con email"
                               TextColor="#4a6a80" FontSize="11"
                               Margin="10,0"/>
                        <BoxView Grid.Column="2" HeightRequest="1"
                                 Color="#1a3040" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Nombre -->
                    <Border BackgroundColor="#162030" StrokeThickness="1" Padding="16,0">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1e3a50"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="Nombre completo"
                               Text="{Binding Nombre}"
                               HeightRequest="52"
                               TextColor="#D8EDF8"
                               PlaceholderColor="#4a6a80"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Correo -->
                    <Border BackgroundColor="#162030" StrokeThickness="1" Padding="16,0">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1e3a50"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="Correo electrónico"
                               Text="{Binding Correo}"
                               Keyboard="Email"
                               HeightRequest="52"
                               TextColor="#D8EDF8"
                               PlaceholderColor="#4a6a80"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Contraseña -->
                    <Border BackgroundColor="#162030" StrokeThickness="1" Padding="16,0">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1e3a50"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="Contraseña"
                               Text="{Binding Password}"
                               IsPassword="True"
                               HeightRequest="52"
                               TextColor="#D8EDF8"
                               PlaceholderColor="#4a6a80"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Mensaje -->
                    <Label Text="{Binding Mensaje}"
                           TextColor="#ef5350"
                           FontSize="13"
                           HorizontalOptions="Center"/>

                    <!-- ActivityIndicator -->
                    <ActivityIndicator IsRunning="{Binding Cargando}"
                                       IsVisible="{Binding Cargando}"
                                       Color="#3898DC"
                                       HorizontalOptions="Center"/>

                    <!-- Botón registrar -->
                    <Button Text="Registrarme"
                            Command="{Binding RegistrarCommand}"
                            HeightRequest="52"
                            CornerRadius="12"
                            FontAttributes="Bold"
                            FontSize="15"
                            Margin="0,4,0,0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1878b4" Offset="0"/>
                                <GradientStop Color="#0d5a8a" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>

                    <!-- Ir a login -->
                    <Button Text="¿Ya tienes cuenta? Inicia sesión"
                            Command="{Binding IrALoginCommand}"
                            HeightRequest="52"
                            CornerRadius="12"
                            FontSize="13"
                            BackgroundColor="Transparent"
                            TextColor="#3898DC"
                            BorderColor="#1e3a50"
                            BorderWidth="1"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>