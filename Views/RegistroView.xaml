<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FatigaVisualApp.ViewModels"
             x:Class="FatigaVisualApp.Views.RegistroView"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="40,60,40,40" Spacing="24" VerticalOptions="Center">

            <Image Source="logo.png"
                   HeightRequest="120"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10"/>

            <StackLayout Spacing="4">
                <Label Text="Crear cuenta" FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#2D3436"/>
                <Label Text="Regístrate para comenzar a cuidar tu visión" FontSize="14"
                       HorizontalOptions="Center" TextColor="#636E72"/>
            </StackLayout>

            <VerticalStackLayout Spacing="16" Margin="0,16,0,0">
                <Entry Placeholder="Nombre completo"
                       Text="{Binding Nombre}"
                       BackgroundColor="#F5F5F5"
                       HeightRequest="50"/>

                <Entry Placeholder="Correo electrónico"
                       Text="{Binding Correo}"
                       Keyboard="Email"
                       BackgroundColor="#F5F5F5"
                       HeightRequest="50"/>

                <Entry Placeholder="Contraseña"
                       Text="{Binding Password}"
                       IsPassword="True"
                       BackgroundColor="#F5F5F5"
                       HeightRequest="50"/>
            </VerticalStackLayout>

            <Button Text="Registrarme"
                    BackgroundColor="#1D9E75"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="10"
                    Command="{Binding RegistrarCommand}"/>

            <Button Text="¿Ya tienes cuenta? Inicia sesión"
                    BackgroundColor="Transparent"
                    TextColor="#1D9E75"
                    FontSize="14"
                    Command="{Binding IrALoginCommand}"/>

            <ActivityIndicator IsRunning="{Binding Cargando}"
                               IsVisible="{Binding Cargando}"
                               Color="#1D9E75"/>

            <Label Text="{Binding Mensaje}"
                   TextColor="#1D9E75"
                   HorizontalOptions="Center"
                   FontAttributes="Italic"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>