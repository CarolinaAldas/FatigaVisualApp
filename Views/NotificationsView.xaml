<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.NotificationsView"
             BackgroundColor="white"
             Title="Notificaciones">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <Border BackgroundColor="#1D9E75" 
                    StrokeShape="RoundRectangle 24"
                    Padding="24" 
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="Pausa 20-20-20"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="Es hora de descansar la vista"
                           FontSize="13" TextColor="White" Opacity="0.85"
                           HorizontalOptions="Center"/>

                    <Border StrokeShape="Ellipse" WidthRequest="120"
                            HeightRequest="120" Padding="0"
                            BackgroundColor="#17845F"
                            HorizontalOptions="Center"
                            StrokeThickness="0"
                            Margin="0,12,0,12">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="restante" FontSize="11" TextColor="White" Opacity="0.75" HorizontalOptions="Center"/>
                            <Label Text="{Binding TiempoRestante}" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="{Binding TextoBoton}"
                            BackgroundColor="White" TextColor="#1D9E75"
                            CornerRadius="20" FontAttributes="Bold"
                            WidthRequest="160" HorizontalOptions="Center"
                            Command="{Binding ToggleTimerCommand}"/>

                    <Label Text="{Binding PausasCompletadas, StringFormat='Pausas completadas hoy: {0}'}"
                           FontSize="12" TextColor="White" Opacity="0.85"
                           HorizontalOptions="Center" Margin="0,8,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Configurar recordatorios"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="#2D3436" Margin="0,8,0,0"/>

            <VerticalStackLayout Spacing="16">
                <Border StrokeShape="RoundRectangle 16" Padding="16"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" 
                                Padding="0" BackgroundColor="#E1F5EE" StrokeThickness="0">
                            <Label Text="👁️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Regla 20-20-20" FontSize="14" FontAttributes="Bold" TextColor="#2D3436"/>
                            <Label Text="Cada 20 minutos" FontSize="12" TextColor="#636E72"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding Notif2020Activa}" OnColor="#1D9E75" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Border StrokeShape="RoundRectangle 16" Padding="16"
                        BackgroundColor="White" Stroke="#F5F5F5">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" 
                                Padding="0" BackgroundColor="#FAEEDA" StrokeThickness="0">
                            <Label Text="💧" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Recordatorio de parpadeo" FontSize="14" FontAttributes="Bold" TextColor="#2D3436"/>
                            <Label Text="Cada hora" FontSize="12" TextColor="#636E72"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding NotifParpadeoActiva}" OnColor="#1D9E75" VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>