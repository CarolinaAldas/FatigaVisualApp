<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatigaVisualApp.Views.StatsView"
             Title="Mi progreso">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <VerticalStackLayout IsVisible="{Binding NoHayDatos}" Spacing="16" Margin="0,40,0,0">
                <Label Text="📊" FontSize="64" HorizontalOptions="Center"/>
                <Label Text="Aún no tienes evaluaciones" FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#2D3436"/>
                <Label Text="Completa tu primera evaluación para ver tu progreso"
                       FontSize="14" TextColor="#636E72" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Button Text="Hacer evaluación" BackgroundColor="#1D9E75" TextColor="White"
                        CornerRadius="10" HeightRequest="50" Margin="0,16"
                        Command="{Binding IrACuestionarioCommand}"/>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding HayDatos}" Spacing="24">

                <Border BackgroundColor="{Binding ColorNivel}" StrokeShape="RoundRectangle 24"
                        Padding="24" StrokeThickness="0">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Último resultado" FontSize="14" TextColor="White" Opacity="0.9"/>
                        <Label Text="{Binding UltimoIndice}" FontSize="56" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding UltimoNivel}" FontSize="15" TextColor="White" FontAttributes="Bold"/>
                        <Label Text="{Binding Tendencia}" FontSize="13" TextColor="White" Opacity="0.85" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 16" Padding="12"
                            BackgroundColor="White" Stroke="#F5F5F5">
                        <VerticalStackLayout>
                            <Label Text="{Binding TotalEvaluaciones}" FontSize="24" FontAttributes="Bold" TextColor="#1D9E75" HorizontalOptions="Center"/>
                            <Label Text="Total" FontSize="11" TextColor="#636E72" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Padding="12"
                            BackgroundColor="White" Stroke="#F5F5F5">
                        <VerticalStackLayout>
                            <Label Text="{Binding MejorIndice}" FontSize="24" FontAttributes="Bold" TextColor="#1D9E75" HorizontalOptions="Center"/>
                            <Label Text="Mejor" FontSize="11" TextColor="#636E72" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 16" Padding="12"
                            BackgroundColor="White" Stroke="#F5F5F5">
                        <VerticalStackLayout>
                            <Label Text="{Binding PeorIndice}" FontSize="24" FontAttributes="Bold" TextColor="#D63031" HorizontalOptions="Center"/>
                            <Label Text="Peor" FontSize="11" TextColor="#636E72" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="Historial de evaluaciones" FontSize="18" FontAttributes="Bold" TextColor="#2D3436"/>

                <CollectionView ItemsSource="{Binding Historial}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Border Margin="0,6" StrokeShape="RoundRectangle 12" Padding="16"
                                    Stroke="#F5F5F5" BackgroundColor="White">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="14" TextColor="#2D3436"/>
                                        <Label Text="{Binding Nivel}" FontSize="12" TextColor="#636E72"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding IndiceFatiga, StringFormat='{0}/100'}"
                                           FontSize="16" FontAttributes="Bold" TextColor="#1D9E75" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="Nueva evaluación" BackgroundColor="#1D9E75" TextColor="White"
                        CornerRadius="10" HeightRequest="50" Margin="0,0,0,20"
                        Command="{Binding IrACuestionarioCommand}"/>

            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding Cargando}" IsVisible="{Binding Cargando}" Color="#1D9E75"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>